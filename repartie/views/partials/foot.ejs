  </main>

  <footer class="footer">
    <p class="footer-mark"><%= settings.footer_text %></p>

    <p class="footer-state">
      <% if (window.state === 'open') { %>
        Open for submissions<%= window.closesOn ? ' until ' + longDate(window.closesOn) : '' %>
      <% } else if (window.state === 'upcoming') { %>
        Reading opens <%= longDate(window.opensOn) %>
      <% } else { %>
        Submissions closed
      <% } %>
    </p>

    <nav class="footer-admin" aria-label="Administrative">
      <% if (owner) { %>
        <a href="/admin">Administrative</a>
        <form method="post" action="/logout"><button type="submit" class="linkish">Sign out</button></form>
      <% } else { %>
        <a href="/login">Administrative</a>
      <% } %>
    </nav>

    <%# Not a setting. Fixed, and not editable from the desk. %>
    <p class="footer-credit">Website built by Emmet</p>
  </footer>
</body>
</html>
