# Copy to .env for local development. On Render, set these in the dashboard.

# Long random string. Signs the session cookie. Change it.
SESSION_SECRET=please-generate-a-long-random-string

# The first owner account, created on first boot if no owner exists.
# Readers never have accounts, so this is the only login there is.
OWNER_EMAIL=you@example.com
OWNER_PASSWORD=change-this-before-you-deploy
OWNER_NAME=Your Name

# Where the SQLite file is written.
# Local: leave unset (defaults to ./data). On Render: /var/data
# DATA_DIR=/var/data

# The timezone the submission window opens and closes in.
SITE_TZ=America/Los_Angeles

NODE_ENV=development
