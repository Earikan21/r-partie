<%- include('partials/head', { pageTitle: 'An invitation' }) %>

<div class="column" style="max-width:26rem">
  <p class="eyebrow">An invitation</p>
  <h1>Join the desk</h1>
  <p class="standfirst">
    You have been asked to help run <%= settings.site_title %>. Set a password and the desk
    is yours: submissions, issues, and every word on the site.
  </p>

  <p class="notice">
    Signing in as <strong><%= invite.email %></strong><br>
    <span class="muted">This is the address the invitation was sent to. It cannot be changed here.</span>
  </p>

  <% if (error) { %><p class="notice notice-alarm"><%= error %></p><% } %>

  <form method="post" action="/invite/<%= invite.token %>">
    <div class="field">
      <label for="name">Your name</label>
      <input type="text" id="name" name="name" value="<%= values.name || '' %>" required autofocus>
      <span class="hint">What the other owners will see next to your name.</span>
    </div>

    <div class="field">
      <label for="password">Choose a password</label>
      <input type="password" id="password" name="password" minlength="10" required>
      <span class="hint">At least 10 characters. Nobody else ever sees it, not even whoever invited you.</span>
    </div>

    <div class="field">
      <label for="confirm">Again</label>
      <input type="password" id="confirm" name="confirm" minlength="10" required>
    </div>

    <button class="btn" type="submit">Accept and sign in</button>
  </form>
</div>

<%- include('partials/foot') %>
